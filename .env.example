# ═══════════════════════════════════════════════════════
# PASCOM — Variáveis de Ambiente (TEMPLATE SEGURO)
# ═══════════════════════════════════════════════════════
#
# INSTRUCOES:
#   1. Copie este arquivo para ".env" (git-ignorado)
#   2. Preencha com suas credenciais REAIS
#   3. NUNCA commite o arquivo ".env" — apenas este ".env.example"
#
# Para desenvolvimento local: cp .env.example .env
# Para producao: configure variaveis diretamente no painel do servidor (cPanel, Docker, etc.)
#
# ────────────────────────────────────────────────────────

# Banco de Dados MySQL/MariaDB
DB_HOST=localhost
DB_USER=seu_usuario_aqui
DB_PASS=sua_senha_segura_aqui
DB_NAME=seu_banco_aqui
