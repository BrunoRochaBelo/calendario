{
    "name": "brunorochabelo/calendario",
    "description": "Sistema de Calendário e Agendamentos da Paróquia",
    "type": "project",
    "require": {
        "setasign/fpdf": "^1.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "files": ["includes/helpers.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "pre-dev": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "dev": [
            "docker compose up -d",
            "docker compose logs -f"
        ],
        "test": [
            "docker compose exec -T app ./vendor/bin/phpunit"
        ],
        "down": [
            "docker compose down"
        ],
        "shell": [
            "docker compose exec app bash"
        ],
        "db": [
            "docker compose exec -it db mariadb -u root -p"
        ]
    }
}
